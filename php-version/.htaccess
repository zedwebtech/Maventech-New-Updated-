# =============================================================================
# Maventech Admin Panel — Apache hardening (cPanel / Plesk / shared hosting)
# =============================================================================

# ---- Force UTF-8 ----
AddDefaultCharset UTF-8

# ---- Block direct access to sensitive files ----
<FilesMatch "^(database\.sql|start\.sh|seed-templates\.php|router\.php|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

# ---- Block dotfiles and backup files ----
<FilesMatch "^\.(env|git|htaccess|htpasswd|DS_Store)|~$|\.bak$|\.old$|\.swp$">
    Require all denied
</FilesMatch>

# ---- Block direct access to the includes/ and lib/ directories ----
RedirectMatch 404 ^/includes/
RedirectMatch 404 ^/lib/
RedirectMatch 404 ^/vendor/

# ---- Block raw access to customer-PII PDFs (receipts/invoices).
#      These must only be served via order-history.php which checks
#      the email + order-number session unlock. ----
RewriteEngine On
RewriteRule ^uploads/order-pdfs/.* - [F,L]

# ---- Pretty SEO endpoints — proxy /sitemap.xml, /merchant-feed.xml, /llms.txt,
#      /robots.txt and /ai.txt through their PHP generators so they always
#      reflect the live host + catalogue + company info. ----
RewriteRule ^sitemap\.xml$        sitemap-xml.php   [L]
RewriteRule ^merchant-feed\.xml$  merchant-feed.php [L]
RewriteRule ^llms\.txt$           llms-txt.php      [L]
RewriteRule ^agents\.json$        agents-json.php   [L]
RewriteRule ^robots\.txt$         robots-txt.php    [L]
RewriteRule ^ai\.txt$             ai-txt.php        [L]

# ---- Google Merchant Center / Bing Shopping / Meta Catalog: extra aliases ----
# Google's Merchant Center accepts ANY URL that returns valid RSS/XML with the
# g: namespace, but merchants commonly type feed URLs from muscle memory:
# feed.xml, products.xml, google-products.xml, etc.  Without these aliases the
# storefront returns its HTML 404 page and Merchant Center reports:
#     "Feed file is in a format that we don't support: HTML"
# All aliases resolve to the same merchant-feed.php generator (RSS 2.0 with
# the g:namespace) — safe to point Merchant Center / Bing / Meta at any of them.
RewriteRule ^feed\.xml$                   merchant-feed.php [L]
RewriteRule ^feeds/products\.xml$         merchant-feed.php [L]
RewriteRule ^products\.xml$               merchant-feed.php [L]
RewriteRule ^product-feed\.xml$           merchant-feed.php [L]
RewriteRule ^google-products\.xml$        merchant-feed.php [L]
RewriteRule ^google-shopping-feed\.xml$   merchant-feed.php [L]
RewriteRule ^shopping-feed\.xml$          merchant-feed.php [L]
RewriteRule ^shopping\.xml$               merchant-feed.php [L]
RewriteRule ^gmc\.xml$                    merchant-feed.php [L]
RewriteRule ^gmc-feed\.xml$               merchant-feed.php [L]
RewriteRule ^merchant\.xml$               merchant-feed.php [L]
RewriteRule ^feed/google-products\.xml$   merchant-feed.php [L]
RewriteRule ^feeds/google-products\.xml$  merchant-feed.php [L]
RewriteRule ^feed/bing-shopping\.xml$     merchant-feed.php [L]
RewriteRule ^feeds/bing-shopping\.xml$    merchant-feed.php [L]
RewriteRule ^bing-shopping-feed\.xml$     merchant-feed.php [L]
RewriteRule ^microsoft-merchant-feed\.xml$ merchant-feed.php [L]
RewriteRule ^meta-catalog\.xml$           merchant-feed.php [L]
RewriteRule ^facebook-catalog\.xml$       merchant-feed.php [L]

# ============================================================================
# SEO — Google Search Console legacy-URL clean-up (2026-07)
# Fixes reported issues:
#   • "Duplicate, Google chose different canonical than user"  → canonical → www
#   • "Not found (404)"                                        → 301 old WP URLs
#   • "Blocked due to access forbidden (403)" on /cgi-bin/     → 410 Gone
#   • "Blocked by robots.txt" on ?add-to-cart=…                → 301 clean URL
#   • "Alternate page with proper canonical tag" on /?MA /?NA  → 301 strip params
# These rules mirror the ones in router.php so the dev preview + Apache
# production behave identically.
# ============================================================================

# ---- (a) 410 GONE for permanently-removed WordPress paths.  A 410 tells
#       Google to REMOVE the URL from the index far faster than a 404. ----
RewriteRule ^wp-content(/.*)?$      /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^wp-admin(/.*)?$        /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^wp-includes(/.*)?$     /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^wp-login\.php$         /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^wp-cron\.php$          /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^xmlrpc\.php$           /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^cgi-bin(/.*)?$         /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^feed/?$                /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule ^comments/feed/?$       /legacy-redirect.php?type=gone  [L,R=410,QSA]
# Match /<any-slug>/feed/  BUT keep the merchant XML feeds working
RewriteCond %{REQUEST_URI} !^/feed/(google-products|bing-shopping)\.xml$
RewriteCond %{REQUEST_URI} !^/feeds/
RewriteRule ^[^/]+/feed/?$          /legacy-redirect.php?type=gone  [L,R=410,QSA]
RewriteRule .*/trackback/?$         /legacy-redirect.php?type=gone  [L,R=410,QSA]

# ---- (b) 301 known legacy WordPress permalinks to the new location. ----
RewriteRule ^home/?$                    /                                        [R=301,L]
RewriteRule ^index\.php/?$              /                                        [R=301,L,QSA]
RewriteRule ^microsoft-office-?2019/?$  /hub/office-2019-pc                      [R=301,L]
RewriteRule ^microsoft-office-?2021/?$  /hub/office-2021-pc                      [R=301,L]
RewriteRule ^microsoft-office-?2024/?$  /hub/office-2024-pc                      [R=301,L]
RewriteRule ^office-2019-for-mac/?$     /hub/office-2019-mac                     [R=301,L]
RewriteRule ^office-2021-for-mac/?$     /hub/office-2021-mac                     [R=301,L]
RewriteRule ^office-2024-for-mac/?$     /hub/office-2024-mac                     [R=301,L]
RewriteRule ^microsoft-office/?$        /hub/microsoft-office                    [R=301,L]
RewriteRule ^microsoft-windows/?$       /hub/windows                             [R=301,L]
RewriteRule ^microsoft/?$               /brand.php?slug=microsoft                [R=301,L]
RewriteRule ^bitdefender/?$             /brand.php?slug=bitdefender              [R=301,L]
RewriteRule ^mcafee/?$                  /brand.php?slug=mcafee                   [R=301,L]
RewriteRule ^refund-policy/?$           /page.php?slug=returns-refunds           [R=301,L]
RewriteRule ^privacy-policy/?$          /page.php?slug=privacy-policy            [R=301,L]
RewriteRule ^terms(-of-service)?/?$     /page.php?slug=terms-of-service          [R=301,L]
RewriteRule ^cookie-policy/?$           /page.php?slug=cookie-policy             [R=301,L]
RewriteRule ^disclaimer/?$              /page.php?slug=disclaimer                [R=301,L]
# Brands we don't sell → bounce to the antivirus search
RewriteRule ^f-?secure/?$               /shop.php?q=antivirus                    [R=301,L,NC]
RewriteRule ^avast/?$                   /shop.php?q=antivirus                    [R=301,L,NC]
RewriteRule ^norton/?$                  /shop.php?q=antivirus                    [R=301,L,NC]
RewriteRule ^kaspersky/?$               /shop.php?q=antivirus                    [R=301,L,NC]

# ---- (c) 301 WordPress /product/<slug>/ and /products/<slug>/ URLs to
#       our canonical /product.php page.  legacy-redirect.php does a smart
#       DB slug-lookup and falls back to /shop.php?q=… when the exact
#       product no longer exists. ----
RewriteRule ^(?:product|products|shop|item)/([a-z0-9\-]+)/?$    /legacy-redirect.php?type=product&slug=$1   [R=301,L]
RewriteRule ^(?:product-category|product_cat|category)/([a-z0-9\-]+)/?$  /legacy-redirect.php?type=category&slug=$1  [R=301,L]

# ---- (d) Strip WooCommerce/WordPress query params on the homepage so the
#       hundreds of "Alternate page with proper canonical tag" variants
#       (?add-to-cart=NNN, ?MA, ?NA, ?SA, ?NA&add-to-cart=…) all consolidate
#       into a single 301 → the canonical "/" URL. ----
RewriteCond %{QUERY_STRING} (^|&)add-to-cart=[0-9]+
RewriteRule ^$  /?  [R=301,L]
# Bare WP tracking tokens (?MA, ?NA, ?SA) with no value
RewriteCond %{QUERY_STRING} ^(MA|NA|SA|MD)$  [NC]
RewriteRule ^$  /?  [R=301,L]

# ============================================================================
# END SEO legacy-URL clean-up
# ============================================================================


# ---- Google Merchant + Bing Shopping feed aliases — mirror router.php so all
#      the well-known feed URLs that the Live SEO Health Check links to
#      resolve on Apache too (cPanel / shared hosting).  Without these the
#      /feed/google-products.xml link in the admin panel returns 404 on
#      production even though it works locally behind the dev router. ----
RewriteRule ^feed/google-products\.xml$        merchant-feed.php [L,QSA]
RewriteRule ^feeds/google-products\.xml$       merchant-feed.php [L,QSA]
RewriteRule ^google-merchant-feed\.xml$        merchant-feed.php [L,QSA]
RewriteRule ^google-shopping-feed\.xml$        merchant-feed.php [L,QSA]
RewriteRule ^feed/bing-shopping\.xml$          merchant-feed.php [L,QSA]
RewriteRule ^feeds/bing-shopping\.xml$         merchant-feed.php [L,QSA]
RewriteRule ^bing-shopping-feed\.xml$          merchant-feed.php [L,QSA]
RewriteRule ^microsoft-merchant-feed\.xml$     merchant-feed.php [L,QSA]

# ---- Pretty CONTENT endpoints — mirror router.php so extensionless URLs
#      (press-kit, embed, hub, manifest, OG images) work on Apache too.
#      Without these, /press-kit etc. 404 on the live domain even though
#      they work behind the dev router. ----
RewriteRule ^press-kit/?$                        press-kit.php             [L,QSA]
RewriteRule ^embed/badge(\.js)?$                 embed-badge.php           [L,QSA]
RewriteRule ^embed/?$                            press-kit.php             [L,QSA]

# ---- Clean up legacy /hub/* mis-resolved URLs.  Topic hubs render at the
#      virtual path /hub/<slug>, so older crawls resolved the page's relative
#      links against /hub/ and indexed bogus URLs like /hub/shop.php,
#      /hub/category.php?slug=…, /hub/page.php?…, even /hub/hub/<slug>.
#      301 them to their real root location so Google drops the 404s and
#      consolidates link equity. (New page loads use <base href> and never
#      generate these.)  Must precede the clean /hub/<slug> rule below. ----
RewriteRule ^hub/hub/(.+)$                       /hub/$1                   [R=301,L,QSA]
RewriteCond %{REQUEST_URI} !^/hub/(assets|ajax|uploads)/
RewriteRule ^hub/(.+\.php)$                       /$1                       [R=301,L,QSA]
RewriteRule ^hub/([a-z0-9\-]+)/?$                hub.php?topic=$1          [L,QSA]
RewriteRule ^manifest(\.webmanifest|\.json)?$    manifest-webmanifest.php  [L,QSA]
RewriteRule ^og-default\.(png|jpe?g)$            og-default.php            [L,QSA]
RewriteRule ^og-product\.(png|jpe?g)$            og-product.php            [L,QSA]

# ---- Frequently-guessed alias → canonical contact page (301). ----
RewriteRule ^contact-us(\.php)?/?$  /contact.php  [R=301,L]

# ---- Free Tools clean URLs — /tools and /tools/<slug> must resolve on
#      Apache even without the generic ".php fallback" below (some shared
#      hosts disable multiviews / negotiation).  Explicit rules mean the
#      footer link "All Free Tools" and the individual tool pages always
#      work on the live domain. ----
RewriteRule ^tools/?$                            tools.php                 [L,QSA]
RewriteRule ^tools/([a-z0-9\-]+)/?$              tools/$1.php              [L,QSA]

# ---- SELF-HEAL stacked country prefixes (e.g. /uk/au/shop from an old cached
#      link or stale switcher) — collapse to the FIRST prefix (the region the
#      visitor most recently clicked, which the switcher prepends) and 301 to
#      /uk/shop. Re-runs until a single prefix remains. Must precede the
#      single-prefix rules below. ----
RewriteRule ^(us|uk|au|ca|eu)/(us|uk|au|ca|eu)(/.*)?$  /$1$3  [R=301,L,QSA]

# ---- Regional storefront prefixes (/ca, /uk, /au, /eu) localise the currency;
#      /us is the canonical root and 301-redirects to the bare path. Mirrors
#      router.php so these regional links resolve on Apache / cPanel hosting —
#      without these rules /ca, /uk, /au, /eu return a 404 on the live domain
#      even though they work in the dev preview. The country is handed to PHP
#      as ?mv_cc=XX (read by includes/functions.php to pick the currency). ----
RewriteRule ^us(?:/(.*))?$          /$1                 [R=301,L,QSA]
RewriteRule ^(ca|uk|au|eu)/(.+)$    $2?mv_cc=$1         [QSA,L]
RewriteRule ^(ca|uk|au|eu)/?$       index.php?mv_cc=$1  [QSA,L]

# ---- Generic extensionless → .php fallback.  Any /foo that has a matching
#      foo.php file (and isn't a real file/dir) is served from it.  This
#      keeps every clean URL working on the live server. ----
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^([a-zA-Z0-9_\-/]+?)/?$ $1.php [L,QSA]

# ---- Canonical-host 301 redirect (www ↔ naked).  SEO audit tools flag a
#      site when both http(s)://example.com and http(s)://www.example.com
#      serve the same content without redirecting, because inbound links
#      get split across hosts.  Set ENV `SEO_CANONICAL_HOST` to either
#      'naked' or 'www' to flip the preference site-wide.
#
#      DEFAULT = 'naked' — most shared-hosting SSL certificates (Let's
#      Encrypt / cPanel AutoSSL) are issued only for the naked host
#      unless a separate cert (or SAN) is added for the "www." subdomain.
#      Redirecting naked → www on a naked-only cert triggers
#      NET::ERR_CERT_COMMON_NAME_INVALID in the browser. Keeping the
#      default at 'naked' matches the most common cert setup and can be
#      flipped to 'www' with `SetEnv SEO_CANONICAL_HOST www` in .htaccess
#      or the host's control panel once a wildcard/SAN cert is in place.
#      ---------------------------------------------------------------- */
SetEnvIfNoCase Host ^www\. IS_WWW=1
# Default: redirect www → naked (only when the current request is already HTTPS
# — never redirect into HTTPS if the client is on plain HTTP, otherwise a
# missing/mismatched cert on the target host produces ERR_CERT_* in the browser).
RewriteCond %{ENV:SEO_CANONICAL_HOST} !=www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteCond %{HTTPS} =on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} =https
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
# Opposite: redirect naked → www when the admin explicitly opts in via
# SEO_CANONICAL_HOST=www (only makes sense when the SSL cert covers the
# "www." subdomain — otherwise leave the default).
RewriteCond %{ENV:SEO_CANONICAL_HOST} =www
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|\d+\.\d+\.\d+\.\d+)(:|$) [NC]
RewriteCond %{HTTPS} =on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} =https
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- Disable PHP / shell execution inside uploads/ ----
# Enforced by uploads/.htaccess (FilesMatch deny + RemoveHandler). A <Directory>
# block is invalid in .htaccess context, so the rule lives in uploads/.htaccess.

# ---- Security headers ----
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ---- Disable directory listing ----
Options -Indexes

# ---- Pretty error page for 404 ----
ErrorDocument 404 /404.php

# ---- Text compression — robust across hosts (Brotli → gzip/deflate →
#      legacy mod_gzip). Without this, style.css (~154 KB) + main.js (~48 KB)
#      ship UNCOMPRESSED on hosts where only one module is present, which is
#      the #1 cause of a "heavy/slow" first paint on shared hosting. ----
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json text/xml application/xml application/rss+xml image/svg+xml text/plain application/x-javascript text/javascript
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml application/rss+xml image/svg+xml text/plain application/x-javascript text/javascript application/vnd.ms-fontobject application/x-font-ttf font/opentype text/xsl
</IfModule>
<IfModule mod_gzip.c>
    mod_gzip_on Yes
    mod_gzip_dechunk Yes
    mod_gzip_item_include mime ^text/.*
    mod_gzip_item_include mime ^application/(javascript|json|xml|rss\+xml)
    mod_gzip_item_include mime ^image/svg\+xml
    mod_gzip_item_include file \.(html?|css|js|json|xml|svg|txt)$
</IfModule>

<IfModule mod_mime.c>
    AddType text/xsl .xsl
</IfModule>

# ---- Static-asset cache (1 year) ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ---- Immutable Cache-Control for hashed/versioned static assets ----
# We append ?v=<filemtime> to every CSS/JS we ship, so it's safe to tell
# browsers + CDNs to hold the response for a year without re-validation.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2|woff|ttf|otf|eot|jpg|jpeg|png|webp|avif|svg|ico|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Discovery files refreshed daily — short cache window.
    <FilesMatch "^(llms\.txt|agents\.json|sitemap\.xml|merchant-feed\.xml|robots\.txt)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>
